{
  "name": "teachmo-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:ci": "VITE_SOURCEMAP=false vite build",
    "build:dev": "vite build --mode development",
    "lint": "eslint src backend --ext .js,.jsx,.ts,.tsx",
    "lint:production": "npm run check:lint-ratchet",
    "check:lint-ratchet": "node scripts/check-lint-ratchet.mjs",
    "lint:barrel": "eslint src --ext .js,.jsx,.ts,.tsx --config eslint.barrel.config.js",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:backend": "jest --config jest.backend.config.cjs",
    "test:watch": "jest --watch",
    "test:a11y": "vitest run src/pages/__tests__/Login.a11y.test.jsx src/pages/__tests__/OAuth2Consent.a11y.test.jsx src/pages/__tests__/FounderDashboard.a11y.test.jsx src/pages/__tests__/AITransparency.a11y.test.jsx src/components/layout/__tests__/Header.a11y.test.jsx",
    "test:smoke": "vitest run src/pages/__tests__/Healthz.test.tsx src/components/shared/__tests__/ProtectedRoute.test.tsx src/config/__tests__/env.test.ts src/observability/__tests__/redaction.test.ts src/observability/__tests__/events.test.ts",
    "backend:check": "node --check backend/routes/ops.js",
    "check:size": "node scripts/check-size-ratchet.mjs",
    "check:size:legacy": "size-limit",
    "check:api-boundaries": "node scripts/check-api-boundaries.mjs",
    "check:audit": "node scripts/check-audit.mjs",
    "check:production-auth-safety": "node scripts/check-production-auth-safety.mjs",
    "check:hasura-readiness": "node scripts/check-hasura-readiness.mjs",
    "check:ts-ratchet": "node scripts/check-ts-ratchet.mjs",
    "check:pii-logging": "node scripts/check-pii-logging.mjs",
    "check:secret-hygiene": "node scripts/check-secret-hygiene.mjs",
    "check:nhost-config-safety": "node scripts/check-nhost-config-safety.mjs",
    "check:schema-metadata": "node scripts/ops/validate-schema-metadata.mjs",
    "check:production:fast": "npm run preflight:example && npm run check:audit && npm run check:secret-hygiene && npm run check:nhost-config-safety && npm run check:api-boundaries && npm run check:production-auth-safety && npm run check:hasura-readiness && npm run check:ts-ratchet && npm run check:pii-logging && npm run check:lint-ratchet",
    "check:production": "npm run check:production:fast && npm run lint:production && npm run typecheck && npm run test -- --run && npm run build && npm run check:size",
    "check:launch": "npm run check:production:fast && npm run test:smoke && npm run build && npm run check:size",
    "loadtest:systemHealth": "node scripts/loadtest/systemHealth.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "preview": "vite preview",
    "release:check": "npm run check:production:fast && npm run test:smoke && npm run build",
    "release:pilot": "npm run release:check && echo \"Release checks passed. Push/deploy using the approved platform workflow; no force-push is performed by this script.\"",
    "ship": "npm run release:pilot",
    "ship:legacy-force-push": "node -e \"console.error('DANGER: legacy force-push release path. Requires explicit human approval; prefer npm run release:pilot.'); process.exit(1)\"",
    "prepare": "husky install",
    "e2e": "playwright test",
    "test:e2e": "npm run e2e",
    "e2e:ops": "playwright test --grep @launch-gates",
    "e2e:a11y": "PLAYWRIGHT_WEB_SERVER=true playwright test tests/e2e/a11y.spec.ts",
    "e2e:ui": "playwright test --ui",
    "prebuild": "node scripts/generate-build-meta.mjs",
    "preflight:example": "node scripts/preflight-env.mjs --example",
    "preflight:env": "node scripts/preflight-env.mjs",
    "start": "vite preview --host 0.0.0.0 --port ${PORT:-4173}",
    "release:info": "node scripts/generate-build-meta.mjs && node -e \"console.log(require(\\\"./src/generated/buildMeta.ts\\\"))\"",
    "smoke:hasura-permissions": "node scripts/hasura-permissions-smoke.mjs",
    "migration:ts:inventory": "node scripts/ts-migration-inventory.mjs --write",
    "issues:bootstrap": "node scripts/bootstrap-issue-pack.mjs",
    "issues:sync": "node scripts/sync-issue-pack.mjs",
    "issues:rollup": "node scripts/rollup-program-status.mjs",
    "issues:project-sync": "node scripts/project-sync-issue-pack.mjs",
    "issues:project-status": "node scripts/project-status-automation.mjs",
    "issues:validate": "node scripts/validate-issue-pack.mjs",
    "issues:test": "node --test scripts/issue-pack-core.test.mjs scripts/validate-project-config.test.mjs",
    "checks:test": "node --test scripts/check-api-boundaries.test.mjs scripts/check-production-auth-safety.test.mjs scripts/check-hasura-readiness.test.mjs scripts/check-ts-ratchet.test.mjs scripts/check-pii-logging.test.mjs",
    "issues:go-live": "node scripts/go-live-issue-automation.mjs",
    "issues:smoke-activity": "node scripts/smoke-issue-activity.mjs",
    "issues:project-validate": "node scripts/validate-project-config.mjs",
    "test:scripts": "node --test scripts/check-api-boundaries.test.mjs scripts/check-audit.test.mjs scripts/check-production-auth-safety.test.mjs scripts/check-secret-hygiene.test.mjs scripts/check-nhost-config-safety.test.mjs scripts/check-ts-ratchet.test.mjs scripts/check-hasura-readiness.test.mjs scripts/check-pii-logging.test.mjs"
  },
